<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting...</title>
    <script is:inline>
      // Auto-append trailing slash if missing
      const path = window.location.pathname;
      if (!path.endsWith("/")) {
        window.location.replace(path + "/");
      }
    </script>
  </head>
  <body>
    <p>Redirecting...</p>
  </body>
</html>
